<section class="section">
  <div class="page-width">
    <div class="section-head">
      <span class="eyebrow">Browse</span>
      <h1>{{ 'collections.general.all' | t }}</h1>
    </div>
    <div class="product-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="card">
          <div class="card__media">
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="600" loading="lazy">
            {%- elsif collection.products.first.featured_image -%}
              <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="600" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="card__body">
            <h3 class="card__title">{{ collection.title }}</h3>
            <span class="text-muted">{{ collection.products_count }} products</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
