{%- comment -%}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}
<article class="card">
  <a href="{{ product.url }}" class="card__media" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}"
           alt="{{ product.featured_image.alt | default: product.title | escape }}"
           width="600" height="600" loading="lazy">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'card__media-placeholder' }}
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
      <span class="card__badge">Sale</span>
    {%- elsif product.available == false -%}
      <span class="card__badge">Sold out</span>
    {%- endif -%}
  </a>
  <div class="card__body">
    <h3 class="card__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <div class="card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="sale">{{ product.price | money }}</span>
        <span class="compare">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </div>
    {%- if product.available -%}
      <form method="post" action="{{ routes.cart_add_url }}" class="card__form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn btn--primary btn--block">{{ 'products.product.add_to_cart' | t }}</button>
      </form>
    {%- else -%}
      <a href="{{ product.url }}" class="btn btn--outline btn--block">{{ 'products.product.sold_out' | t }}</a>
    {%- endif -%}
  </div>
</article>
